generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyers            Buyer[]
  campaigns         Campaign[]
  leads             Lead[]
  suppliers         Supplier[]
  users             User[]
  invites           Invite[]
  trackingCampaigns TrackingCampaign[]
  trackingLinks     TrackingLink[]
  clickEvents       ClickEvent[]
}

model User {
  id             String   @id @default(uuid())
  organizationId String
  email          String   @unique
  passwordHash   String
  role           String   @default("admin")
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model Invite {
  id             String   @id @default(uuid())
  organizationId String
  email          String
  role           String   @default("member")
  token          String   @unique
  status         String   @default("pending")
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([email])
}

model Buyer {
  id              String   @id @default(uuid())
  organizationId  String
  name            String
  companyName     String?
  contactName     String?
  email           String?
  webhookUrl      String?
  pingUrl         String?
  postUrl         String?
  timeoutMs       Int?     @default(1500)
  minBid          Decimal? @db.Decimal(10, 2)
  pricePerLead    Decimal? @db.Decimal(10, 2)
  dailyCap        Int?
  status          String
  acceptedStates  String?
  requiredFields  String?
  notes           String?

  acceptanceMode  String   @default("standard")
  acceptancePath  String?
  acceptanceValue String?
  payoutPath      String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id])
  campaignLinks CampaignBuyer[]
  assignedLeads Lead[]
  deliveries    Delivery[]
  pingResults   PingResult[]

  @@index([organizationId])
}

model Supplier {
  id                String   @id @default(uuid())
  organizationId    String
  name              String
  companyName       String?
  contactName       String?
  email             String?
  trafficSource     String?
  defaultCost       Decimal? @db.Decimal(10, 2)
  apiKey            String   @unique
  status            String
  acceptedVerticals String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  leads        Lead[]

  @@index([organizationId])
}

model Campaign {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  slug           String   @unique
  vertical       String
  routingMode    String   @default("direct_post")
  status         String
  inboundRequiredFields String?
  inboundOptionalFields String?
  publisherSpecNotes String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id])
  buyerLinks   CampaignBuyer[]
  leads        Lead[]

  @@index([organizationId])
}

model CampaignBuyer {
  id         String   @id @default(uuid())
  campaignId String
  buyerId    String
  priority   Int      @default(1)
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id])
  buyer    Buyer    @relation(fields: [buyerId], references: [id])

  @@unique([campaignId, buyerId])
  @@index([campaignId])
  @@index([buyerId])
}

model Lead {
  id              String   @id @default(uuid())
  organizationId  String
  campaignId      String
  assignedBuyerId String?
  supplierId      String?

  firstName       String?
  lastName        String?
  email           String?
  phone           String?
  state           String?
  zip             String?

  source          String?
  subId           String?
  publisherId     String?

  cost            Decimal? @db.Decimal(10, 2)
  profit          Decimal? @db.Decimal(10, 2)
  marginPct       Decimal? @db.Decimal(10, 2)

  routingStatus   String   @default("pending")

  clickId         String?
  trackingLinkId  String?
  trackingCampaignId String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  campaign         Campaign          @relation(fields: [campaignId], references: [id])
  assignedBuyer    Buyer?            @relation(fields: [assignedBuyerId], references: [id])
  supplier         Supplier?         @relation(fields: [supplierId], references: [id])
  trackingLink     TrackingLink?     @relation(fields: [trackingLinkId], references: [id])
  trackingCampaign TrackingCampaign? @relation(fields: [trackingCampaignId], references: [id])

  deliveries     Delivery[]
  pingResults    PingResult[]

  @@index([organizationId])
  @@index([campaignId])
  @@index([assignedBuyerId])
  @@index([supplierId])
  @@index([subId])
  @@index([publisherId])
  @@index([source])
  @@index([clickId])
  @@index([trackingLinkId])
  @@index([trackingCampaignId])
  @@index([createdAt])
}

model Delivery {
  id            String   @id @default(uuid())
  leadId        String
  buyerId       String
  status        String
  response      String?
  statusCode    Int?
  attemptNumber Int      @default(1)
  createdAt     DateTime @default(now())

  lead  Lead  @relation(fields: [leadId], references: [id])
  buyer Buyer @relation(fields: [buyerId], references: [id])

  @@index([leadId])
  @@index([buyerId])
  @@index([createdAt])
}

model PingResult {
  id        String   @id @default(uuid())
  leadId    String
  buyerId   String
  status    String
  bid       Decimal? @db.Decimal(10, 2)
  won       Boolean  @default(false)
  response  String?
  error     String?
  createdAt DateTime @default(now())

  lead  Lead  @relation(fields: [leadId], references: [id])
  buyer Buyer @relation(fields: [buyerId], references: [id])

  @@index([leadId])
  @@index([buyerId])
  @@index([createdAt])
}

model TrackingCampaign {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  slug           String   @unique
  destinationUrl String
  status         String   @default("active")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  links        TrackingLink[]
  clicks       ClickEvent[]
  leads        Lead[]

  @@index([organizationId])
  @@index([status])
}

model TrackingLink {
  id                 String   @id @default(uuid())
  organizationId     String
  trackingCampaignId String
  name               String
  slug               String   @unique

  trafficSource      String?
  publisherId        String?
  subId              String?
  subId2             String?
  subId3             String?

  costModel          String   @default("cpc")
  costPerClick       Decimal? @db.Decimal(10, 4)

  destinationUrl     String?
  status             String   @default("active")

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization     Organization     @relation(fields: [organizationId], references: [id])
  trackingCampaign TrackingCampaign @relation(fields: [trackingCampaignId], references: [id])
  clicks           ClickEvent[]
  leads            Lead[]

  @@index([organizationId])
  @@index([trackingCampaignId])
  @@index([trafficSource])
  @@index([publisherId])
  @@index([subId])
  @@index([status])
}

model ClickEvent {
  id                 String   @id @default(uuid())
  organizationId     String
  trackingCampaignId String?
  trackingLinkId     String?

  clickId            String   @unique

  trafficSource      String?
  publisherId        String?
  subId              String?
  subId2             String?
  subId3             String?

  cost               Decimal? @db.Decimal(10, 4)
  destinationUrl     String?

  ipAddress          String?
  userAgent          String?
  referer            String?
  queryString        String?

  createdAt          DateTime @default(now())

  organization     Organization      @relation(fields: [organizationId], references: [id])
  trackingCampaign TrackingCampaign? @relation(fields: [trackingCampaignId], references: [id])
  trackingLink     TrackingLink?     @relation(fields: [trackingLinkId], references: [id])

  @@index([organizationId])
  @@index([trackingCampaignId])
  @@index([trackingLinkId])
  @@index([trafficSource])
  @@index([publisherId])
  @@index([subId])
  @@index([createdAt])
}
